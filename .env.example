# Copy this file to ~/.claude-orchestrator/.env and fill in real values.
# start.sh sources that path on launch (NOT this repo file).

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to manage schedules (admin commands).
# Leave empty for no admins.
ADMIN_USERS=12345678,87654321

# JSON-encoded array of private memory rules. Each rule grants a memory file
# (in ~/.claude-orchestrator/memory/private/) to specific user DM sessions or
# specific group-topic session keys. Default = no private files exposed.
#
# Example: grant alice-notes.md to user 12345678's DM and to one group topic:
# MEMORY_PRIVATE_RULES=[{"file":"alice-notes.md","allowUsers":["12345678"],"allowSessions":["group--1001234567890-topic-5"]}]
MEMORY_PRIVATE_RULES=

# Optional: override the food-analysis HTTP endpoint prompt with user-specific
# context (dietary needs, target macros, cuisines). Must instruct the model to
# return the same JSON shape — see src/http-server.ts for the default.
FOOD_ANALYSIS_PROMPT=

# Optional: HTTP server port (default 7800)
ORCHESTRATOR_HTTP_PORT=7800

# Optional: HTTP bearer token for /analyze-food. If unset, endpoint is open
# (dev mode). start.sh can also pull this from a vault — see start.sh.
ORCHESTRATOR_HTTP_TOKEN=
